# -*- mode: sh; sh-shell: bash -*-
# Guix dev environment for the Kawa Forge Gradle plugin.
# Requires GNU Guix System + direnv.

if ! has guix; then
  log_status "guix not found on PATH -- skipping"
  return 0
fi

watch_file manifest.scm

# Build the profile (see template mod .envrc for the full explanation).
profile="$PWD/.direnv/guix-profile"
mkdir -p "$(dirname "$profile")"
rm -f "$profile"

# Capture the profile path from guix shell.  Let stderr flow to the terminal
# (build progress) and capture only stdout (the path).
profile_path="$(guix shell -m manifest.scm -- sh -c 'echo $GUIX_ENVIRONMENT')"
if test $? -ne 0 || test -z "$profile_path" || ! test -d "$profile_path"; then
  log_error "guix shell failed. Output: $profile_path"
  return 1
fi

ln -sf "$profile_path" "$profile"

if ! test -f "$profile/etc/profile"; then
  log_error "profile missing etc/profile: $profile_path"
  return 1
fi

# shellcheck disable=SC1091
source "$profile/etc/profile"

export JAVA_HOME
JAVA_HOME="$(dirname "$(dirname "$(readlink -f "$profile/bin/javac")")")"

log_status "Kawa Forge Gradle plugin env ready -- JDK $(basename "$JAVA_HOME")"
